{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profiles and roles for customers, staff members, and administrators.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "staff", "admin"] },
        "subRole": { "type": "string" },
        "institutionName": { "type": "string" },
        "institutionType": { "type": "string" },
        "address": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "active", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Bulk product details and general catalogs.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "sku": { "type": "string" },
        "description": { "type": "string" },
        "unit": { "type": "string" },
        "pricePerUnit": { "type": "number" },
        "stock": { "type": "number" },
        "minOrderQty": { "type": "number" },
        "images": { "type": "array" },
        "isActive": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "name", "sku", "pricePerUnit"]
    },
    "Order": {
      "title": "Order",
      "description": "Main transaction storage containing bulk purchasing records.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "institutionName": { "type": "string" },
        "items": { "type": "array" },
        "orderTotal": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "packed", "dispatched", "delivered", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "partial", "paid"] },
        "assignedSalesman": { "type": "string" },
        "deliveryAddress": { "type": "object" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "statusHistory": { "type": "array" }
      },
      "required": ["orderId", "customerId", "items", "orderTotal", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Bulk products catalog"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Orders collection"
    }
  }
}
